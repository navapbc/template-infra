{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>navapbc/strata-lib-renovate:strataTemplate",
    "github>navapbc/strata-lib-renovate:strataTemplateSeparateTemplateOnlyLegacy",
    "github>navapbc/strata-lib-renovate:playwright",
    "github>navapbc/strata-lib-renovate:terraformAwsLambdaRuntimes",

    ":dependencyDashboardApproval"
  ],
  "ignorePresets": [":ignoreModulesAndTests"],
  "gomod": {
    "managerFilePatterns": ["**/go.mod"]
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "github-actions": {
    "managerFilePatterns": [
      "/\\.github/(?:workflows|actions)/.+\\.ya?ml(?:.jinja)?$/"
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "aquasecurity/tfsec-pr-commenter-action"
      ],
      "enabled": false
    },
    {
      "matchManagers": ["terraform", "terraform-version"],
      "matchPackageNames": ["hashicorp/terraform"],
      "groupName": "Terraform Core",
      "dependencyDashboardApproval": true
    },
    {
      "packagePatterns": ["*"],
      "commitMessageExtra": "from {{{currentVersion}}} to {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}{{prettyNewMajor}}{{else}}{{#if isSingleVersion}}{{prettyNewVersion}}{{else}}{{#if newValue}}{{{newValue}}}{{else}}{{{newDigestShort}}}{{/if}}{{/if}}{{/if}}{{/if}}"
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "commitMessagePrefix": "from {{{currentDigestShort}}} to {{{newDigestShort}}}"
    }
  ]
}
