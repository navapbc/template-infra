{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>navapbc/strata-lib-renovate:strataTemplate",

    ":dependencyDashboardApproval"
  ],
  "ignorePresets": [":ignoreModulesAndTests"],
  "gomod": {
    "managerFilePatterns": ["**/go.mod"]
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "github-actions": {
    "managerFilePatterns": [
      "/\\.github/(?:workflows|actions)/.+\\.ya?ml(\\.jinja)?$/"
    ]
  },
  "packageRules": [
    {
      "matchFileNames": ["**/template-only*{/,}**"],
      "commitMessagePrefix": "template-only:",
      "additionalBranchPrefix": "template-only-"
    },
    {
      "groupName": "Playwright",
      "matchPackageNames": [
        "playwright",
        "@playwright/test",
        "mcr.microsoft.com/playwright"
      ],
      "matchDatasources": ["docker", "npm"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update AWS Lambda runtime values in Terraform files",
      "managerFilePatterns": ["/.+\\.tf$/"],
      "matchStrings": [
        ".*#\\s*renovate:\\s*aws-lambda-runtime( versioning=(?<versioning>.*?))?\\s.*?runtime\\s*=\\s*\"(?<currentValue>.*)\"",
        ".*#\\s*renovate:\\s*depName=aws-lambda( versioning=(?<versioning>.*?))?\\s.*?runtime\\s*=\\s*\"(?<currentValue>.*)\"",
        ".*#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s.*?runtime\\s*=\\s*\"(?<currentValue>.*)\""
      ],
      "depNameTemplate": "{{#if depName}}{{{depName}}}{{else}}aws-lambda{{/if}}",
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}endoflife-date{{/if}}",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}regex:^(?<compatibility>[A-Za-z]+)(?<major>\\d+)(\\.(?<minor>\\d+))?(?:.x)?${{/if}}"
    }
  ]
}
